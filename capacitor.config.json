{
  "appId": "com.aethelgard.rpg",
  "appName": "Crônica de Aethelgard",
  "webDir": ".",
  "bundledWebRuntime": false,
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#111318",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    }
  },
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "*.github.io",
      "raw.githubusercontent.com"
    ]
  }
}
